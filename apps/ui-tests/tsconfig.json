{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../",
    "allowJs": true,
    "outDir": "out-tsc/playwright",
    "sourceMap": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/e2e/**/*.ts",
